#!/usr/bin/env bash

## Podman remote connection + farm setup ##

# Farm name used by `podman farm`
FARM_NAME="cluster"

# Connection name used by `podman system connection`
CONNECTION_NAME="slave"

# SSH connection to the remote (slave) node
SLAVE_USER="your-username"
SLAVE_HOST="slave-ip"
SLAVE_SSH_KEY="$HOME/.ssh/id_ed25519"
SLAVE_PODMAN_SOCKET="/run/user/1000/podman/podman.sock"
